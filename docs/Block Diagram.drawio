nd&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;font-size: 8px;&quot;&gt;LINE_CNT&lt;/span&gt;&lt;span style=&quot;font-size: 8px;&quot;&gt;&amp;lt;=359&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;font-size: 12px; direction: rtl;&quot;&gt;&lt;span style=&quot;font-size: 8px;&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;if (PIXEL_CNT = 160) and (LINE_CNT = 120)&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;&amp;nbsp;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;font-size: 12px; direction: rtl;&quot;&gt;&lt;/div&gt;&lt;div style=&quot;font-size: 12px; direction: rtl;&quot;&gt;&lt;/div&gt;&lt;div style=&quot;font-size: 12px; direction: rtl;&quot;&gt;&lt;span style=&quot;font-size: 8px;&quot;&gt;ADD &amp;lt;= 0&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;&amp;nbsp;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;font-size: 12px; direction: rtl;&quot;&gt;&lt;span style=&quot;font-size: 8px;&quot;&gt;WEA &amp;lt;= ACTIVE&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;&amp;nbsp;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;font-size: 12px; direction: rtl;&quot;&gt;&lt;span style=&quot;font-size: 8px;&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&amp;nbsp; elseif PIXEL_CNT &amp;gt; 160 and PIXEL_CNT &amp;lt;= 479&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;&amp;nbsp;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;font-size: 12px; direction: rtl;&quot;&gt;&lt;span style=&quot;font-size: 8px;&quot;&gt;ADD &amp;lt;= ADD +1&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;font-size: 8px;&quot;&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;font-size: 12px; direction: rtl;&quot;&gt;&lt;span style=&quot;font-size: 8px;&quot;&gt;WEA &amp;lt;= ACTIVE&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 